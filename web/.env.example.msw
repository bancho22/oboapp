# ==============================================================================
# LOCAL DEVELOPMENT: Mock Service Worker (MSW)
# ==============================================================================
# Zero-dependency front-end development - no Java, Docker, or Firebase required.
# See docs/setup/quick-start-frontend-msw.md for setup instructions

# Enable MSW mode - intercepts all API calls with mock data
NEXT_PUBLIC_USE_MSW=true

# Disable Firebase emulators (MSW replaces them for front-end work)
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false

# Firebase credentials are NOT required in MSW mode.
# The app automatically uses safe demo values to skip real Firebase auth.

# Google Maps API Key (required for map display)
# Create one at https://console.cloud.google.com/google/maps-apis/overview
# Enable the Maps JavaScript API and restrict to localhost.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Base URL for local development
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Locality for geocoding and maps (e.g., "bg.sofia" for Sofia, Bulgaria)
NEXT_PUBLIC_LOCALITY=bg.sofia

# Message Relevance Period (in days)
MESSAGE_RELEVANCE_DAYS=7
